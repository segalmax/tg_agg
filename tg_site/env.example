# Django Settings
SECRET_KEY=your-secret-key-here-generate-random
DEBUG=True

# Database - PostgreSQL (for semantic search with pgvector)
# Local: localhost, Production via Railway: see Railway PostgreSQL Variables
DB_NAME=tg_videos
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Telegram API (Required for telegram-monitor service only, not web service)
# Get these from https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash
SESSION_STRING=your_session_string

